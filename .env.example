# Copy to .env on your Linux server and fill in your own values.
export ZOTERO_LIBRARY_ID=123456
export ZOTERO_API_KEY=replace_with_your_zotero_api_key

# Optional. Use "group" for group libraries.
export ZOTERO_LIBRARY_TYPE=user

# Optional. Created automatically if it does not exist.
export ZOTERO_COLLECTION="New Imports"

# Optional. Crossref recommends identifying a contact email for polite API use.
export CROSSREF_MAILTO="you@example.com"
